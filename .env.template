# Application Configuration Template
# Copy this file to .env and customize the values

# Platform type
PLATFORM=pc

# Username for the application
USERNAME=noiprocs

# Application type (client or server)
TYPE=client

# Server hostname
HOSTNAME=localhost

# Server port
PORT=8080

# Directory where all JSON files live at runtime (written by the console-color build).
# Must be an absolute path. Defaults to target/classes when unset.
JSON_EXTRA_OUTPUT_DIR=/absolute/path/to/dir
